{
  "name": "generador-reportes-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve --open",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:iis:root": "ng build --configuration production --base-href / --deploy-url /",
    "build:iis:pruebagx": "ng build --configuration production --base-href /PruebaGX_Web/ --deploy-url /PruebaGX_Web/",
    "sync:iis-package": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Copy-Item -Path 'dist/generador-reportes-frontend/*' -Destination 'IIS-Deploy-Package' -Recurse -Force\"",
    "build:iis:pruebagx:package": "npm run build:iis:pruebagx && npm run sync:iis-package",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/material": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "ag-grid-angular": "32.3.9",
    "ag-grid-community": "32.3.9",
    "ag-grid-enterprise": "32.3.9",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "hyperformula": "^3.2.0",
    "jspreadsheet-ce": "^5.0.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.14.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.5.0"
  }
}
